datasource db {
  provider  = "postgresql"
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String       @id @default(uuid())
  name           String?
  email          String       @unique
  hashedPassword String
  image          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  memberships    Membership[]
}

model Organization {
  id           String        @id @default(uuid())
  name         String
  slug         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // WhatsApp Business credentials (per-org after Embedded Signup)
  whatsappBusinessAccountId String?
  whatsappPhoneNumberId    String?
  metaBusinessId           String?
  wabaScopedUserId         String?
  whatsappConnected        Boolean    @default(false)

  // Wallet & SaaS credits
  walletBalance            Float      @default(0.0)

  // Onboarding state
  onboardingDismissed      Boolean    @default(false)

  memberships  Membership[]
  contacts     Contact[]
  campaigns    Campaign[]
  templates    Template[]
  chatbotNodes ChatbotNode[]
  integrations Integration[]
  systemLogs   SystemLog[]
  messages     Message[]
  products     Product[]
  orders       Order[]
}

enum Role {
  OWNER
  ADMIN
  AGENT
}

model Membership {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role         @default(AGENT)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
}

model Contact {
  id             String       @id @default(uuid())
  name           String
  phone          String
  email          String
  source         String
  tags           String[]     // Postgres scalar list support
  status         String       // "Active" | "Inactive"
  lastMessage    String?
  lastMessageTime String?
  unreadCount    Int          @default(0)
  assignedAgent  String       @default("None")
  currentNodeId  String?      // Tracks position in chatbot flow tree
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       Message[]
  cart           Cart?
  orders         Order[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Message {
  id             String       @id @default(uuid())
  sender         String       // "user" | "agent" | "system"
  text           String       @db.Text
  timestamp      String
  status         String?      // "sent" | "delivered" | "read"
  buttons        String[]     // Postgres scalar list support
  contactId      String
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  waMessageId    String?      // WhatsApp API message ID for delivery tracking
  campaignId     String?      // Links broadcast messages to a campaign for targeted log queries
  createdAt      DateTime     @default(now())
}

model Campaign {
  id             String       @id @default(uuid())
  name           String
  targetTag      String
  templateName   String
  sent           Int          @default(0)
  delivered      Int          @default(0)
  read           Int          @default(0)
  clicked        Int          @default(0)
  status         String       // "Completed" | "Active" | "Scheduled" | "Sending"
  date           String
  
  // New scheduling & media fields
  scheduledAt    DateTime?
  excludeTag     String?
  mediaType      String?      // "image" | "video" | "document" | "none"
  mediaUrl       String?
  variables      Json?
  delay          Int?         @default(1)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model Template {
  id             String       @id @default(uuid())
  name           String
  body           String       @db.Text
  category       String       // "Marketing" | "Utility" | "Authentication"
  buttons        String[]     // Postgres scalar list support
  mediaType      String       @default("none") // "none" | "image" | "video" | "document"
  metaStatus     String       @default("pending") // "pending" | "approved" | "rejected"
  metaId         String?      // Meta template ID for status polling
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model ChatbotNode {
  id             String       // Keep visual IDs: n1, n2, n3...
  type           String       // "trigger" | "message" | "question" | "delay"
  title          String
  content        String       @db.Text
  options        String[]     // Postgres scalar list
  delayTime      Int?
  nextId         String?
  routes         Json?        // Stores options routing dynamically
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@id([id, organizationId])
}

model Integration {
  id             String       // shopify, woocommerce, gsheets etc
  name           String
  description    String       @db.Text
  status         String       // "connected" | "disconnected"
  icon           String
  apiKey         String?      @db.Text
  webhookUrl     String?      @db.Text
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@id([id, organizationId])
}

model SystemLog {
  id             String       @id @default(uuid())
  timestamp      String
  type           String       // "campaign" | "chat" | "integration" | "crm"
  message        String       @db.Text
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaignId     String?      // Links log to a campaign for precise filtering in reports
  createdAt      DateTime     @default(now())
}

model Product {
  id             String       @id @default(uuid())
  name           String
  description    String       @db.Text
  price          Int          // in paise (₹100 = 10000)
  images         String[]
  category       String
  stock          Int          @default(0)
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  cartItems      CartItem[]
  orderItems     OrderItem[]
}

model Cart {
  id        String     @id @default(uuid())
  contactId String
  contact   Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([contactId])
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
}

model Order {
  id                String       @id @default(uuid())
  orderId           String       @unique
  contactId         String
  contact           Contact      @relation(fields: [contactId], references: [id])
  items             OrderItem[]
  total             Int
  status            String       @default("pending") // "pending" | "confirmed" | "processing" | "shipped" | "delivered" | "cancelled"
  paymentStatus     String       @default("pending") // "pending" | "paid" | "failed" | "refunded"
  razorpayOrderId   String?      @unique
  razorpayPaymentId String?
  razorpaySignature String?
  address           Json?
  phone             String
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Int
  quantity  Int
}
